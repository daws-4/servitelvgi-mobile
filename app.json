{
  "expo": {
    "name": "ENLARED TÉCNICOS",
    "slug": "enlared-mobile",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/logo_bgless_resized.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "com.enlared.mobile",
    "notification": {
      "icon": "./assets/notification_icon_white.png",
      "color": "#3e78b2",
      "androidMode": "default",
      "androidCollapsedTitle": "ENLARED"
    },
    "splash": {
      "image": "./assets/splash_optimized.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enlared.mobile",
      "config": {
        "googleMapsApiKey": "AIzaSyDTyGS8C9ytWCV79-eh3mwE6LHmO2h-vLY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Esta app necesita tu ubicación para mostrarte la ruta a las órdenes de servicio.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para capturar evidencia fotográfica de las instalaciones.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para adjuntar evidencia de las instalaciones."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "minSdkVersion": 26,
      "targetSdkVersion": 34,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_bgless_resized.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.enlared.mobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDTyGS8C9ytWCV79-eh3mwE6LHmO2h-vLY"
        }
      },
      "useNextNotificationsApi": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "softInputMode": "adjustPan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que ENLARED acceda a tu ubicación."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que ENLARED use tu cámara para capturar fotos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification_icon_white.png",
          "color": "#3e78b2"
        }
      ],
      [
        "expo-maps",
        {
          "googleMapsApiKey": "AIzaSyDTyGS8C9ytWCV79-eh3mwE6LHmO2h-vLY"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "29a3ed1f-4766-4082-a596-18a590563bd1"
      }
    },
    "owner": "dawszz_4"
  }
}
