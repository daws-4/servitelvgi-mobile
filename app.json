{
  "expo": {
    "name": "Servitelv Mobile",
    "slug": "servitelv-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.servitelv.mobile",
      "config": {
        "googleMapsApiKey": "AIzaSyDTyGS8C9ytWCV79-eh3mwE6LHmO2h-vLY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Esta app necesita tu ubicación para mostrarte la ruta a las órdenes de servicio.",
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para capturar evidencia fotográfica de las instalaciones.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tus fotos para adjuntar evidencia de las instalaciones."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.servitelv.mobile",
      "config": {
        "googleMaps": {
          "apiKey": "TU_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/lora/Lora_400Regular.ttf",
            "./node_modules/@expo-google-fonts/lora/Lora_700Bold.ttf"
          ]
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que Servitel acceda a tu ubicación."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que Servitel use tu cámara para capturar fotos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3e78b2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aa381af0-1677-4006-8b51-888f05d73e1b"
      }
    },
    "owner": "dawszz_4"
  }
}
